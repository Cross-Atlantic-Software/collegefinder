# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# lock files
package-lock.json
**/package-lock.json
pnpm-lock.yaml
yarn.lock

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
aws.txt
/aws/

# SSH keys and private keys
*.pub
*rsa*key*
*ed25519*
id_rsa
id_ed25519
*.key

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Playbook prompt cache – JSON only (remove this line to commit cache and share across runs)
python-backend/app/playbooks/cache/*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python Backend
python-backend/venv/
python-backend/__pycache__/
python-backend/**/__pycache__/
python-backend/*.pyc
python-backend/.env

# Stagehand Backend
stagehand-backend/node_modules/
stagehand-backend/dist/
stagehand-backend/.env

# Backend
backend/node_modules/
backend/.env
backend/npm-install.log
deploy.log

# IDE
.idea/
*.swp
*.swo
