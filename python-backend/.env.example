# ============= Required =============
# Google Gemini API key (for LLM vision decisions)
# Get one: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# PostgreSQL (shared with collegefinder backend)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=collegefinder_db
DB_USER=postgres
DB_PASSWORD=postgres

# ============= Optional =============
# Browserbase (only if using cloud browser instead of local)
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# SMTP for notifications (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Captcha auto-solve (optional)
# CAPTCHA_PROVIDER=
# CAPTCHA_API_KEY=

# URLs (defaults shown)
# STAGEHAND_URL=http://localhost:3001
# FRONTEND_URL=http://localhost:3000
# COLLEGEFINDER_URL=http://localhost:5001/api
