{
  "manifest_version": 3,
  "name": "ExamFill — Exam Form Assistant",
  "version": "1.0.0",
  "description": "Fill Indian competitive exam registration forms in under 5 minutes with your pre-loaded profile data.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs"
  ],

  "host_permissions": [
    "https://jeemain.nta.nic.in/*",
    "https://neet.nta.nic.in/*",
    "https://cuet.samarth.ac.in/*",
    "https://mhtcet2025.mahacet.org/*",
    "https://www.bitsadmission.com/*",
    "https://viteee.vit.ac.in/*",
    "https://stureg.nata-app.org/*",
    "https://nata-app.org/*",
    "https://*.s3.amazonaws.com/*",
    "https://*.s3.ap-south-1.amazonaws.com/*",
    "https://college-finder.s3.ap-south-1.amazonaws.com/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },

  "content_scripts": [
    {
      "matches": [
        "https://jeemain.nta.nic.in/*",
        "https://neet.nta.nic.in/*",
        "https://cuet.samarth.ac.in/*",
        "https://mhtcet2025.mahacet.org/*",
        "https://www.bitsadmission.com/*",
        "https://viteee.vit.ac.in/*",
        "https://stureg.nata-app.org/*",
        "https://nata-app.org/*"
      ],
      "js": [
        "utils/resolver.js",
        "utils/formatter.js",
        "utils/waiter.js",
        "content/detector.js",
        "content/filler.js",
        "content/verifier.js",
        "content/highlighter.js",
        "content/content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "ExamFill",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
