{
  "manifest_version": 3,
  "name": "UniTracko - 1Click",
  "version": "1.1.0",
  "description": "Fill Indian competitive exam registration forms in under 5 minutes with your pre-loaded profile data.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs",
    "cookies"
  ],

  "host_permissions": [
    "https://unitracko.com/*",
    "https://*.nata-app.org/*",
    "https://*.srmist.edu.in/*",
    "https://*.nta.nic.in/*",
    "https://*.samarth.ac.in/*",
    "https://*.mahacet.org/*",
    "https://*.bitsadmission.com/*",
    "https://*.vit.ac.in/*",
    "https://*.eduquity.com/*",
    "https://*.upes.ac.in/*",
    "https://*.bennett.edu.in/*",
    "https://*.pearlacademy.com/*",
    "https://*.ssc.gov.in/*",
    "https://ssc.gov.in/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:5001/*",
    "http://127.0.0.1:5001/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.nata-app.org/*",
        "https://*.srmist.edu.in/*",
        "https://*.nta.nic.in/*",
        "https://*.samarth.ac.in/*",
        "https://*.mahacet.org/*",
        "https://*.bitsadmission.com/*",
        "https://*.vit.ac.in/*",
        "https://*.eduquity.com/*",
        "https://*.upes.ac.in/*",
        "https://*.bennett.edu.in/*",
        "https://*.pearlacademy.com/*",
        "https://*.ssc.gov.in/*",
        "https://ssc.gov.in/*"
      ],
      "js": [
        "utils/resolver.js",
        "utils/formatter.js",
        "utils/waiter.js",
        "content/detector.js",
        "content/filler.js",
        "content/verifier.js",
        "content/highlighter.js",
        "content/pageScanner.js",
        "content/content_script.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://unitracko.com/*",
        "https://*.unitracko.com/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": [
        "content/authSync.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "UniTracko - 1Click",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
