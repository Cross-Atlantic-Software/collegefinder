{
  "manifest_version": 3,
  "name": "ExamFill — Exam Form Assistant",
  "version": "1.1.0",
  "description": "Fill Indian competitive exam registration forms in under 5 minutes with your pre-loaded profile data.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/resolver.js",
        "utils/formatter.js",
        "utils/waiter.js",
        "content/detector.js",
        "content/filler.js",
        "content/verifier.js",
        "content/highlighter.js",
        "content/pageScanner.js",
        "content/content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "ExamFill",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
