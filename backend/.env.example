# Backend environment variables
# Copy to .env and fill in values. Required for mock test generation: GOOGLE_API_KEY.

# Database (Docker: use postgres/redis as host when running in compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=collegefinder_db
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (Docker: use redis as host)
REDIS_HOST=localhost
REDIS_PORT=6379

# Gemini / Google AI (AI Studio) – for mock tests / Gemini features only.
# This is NOT the same as a Google Cloud API key and does NOT work with YouTube Data API.
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Optional: force a specific Gemini model (e.g. gemini-1.5-flash)
# GEMINI_MODEL=

# YouTube lecture descriptions (self-study admin) – separate key from Google CLOUD Console.
# AI Studio / Gemini GOOGLE_API_KEY above cannot be used here.
# 1) https://console.cloud.google.com/ → select/create project
# 2) APIs & Services → Library → enable "YouTube Data API v3"
# 3) APIs & Services → Credentials → Create API key
# YOUTUBE_API_KEY=paste_cloud_console_api_key_here

# Server
PORT=5001
NODE_ENV=development

# Frontend URL for CORS (optional)
# FRONTEND_URL=http://localhost:3000
