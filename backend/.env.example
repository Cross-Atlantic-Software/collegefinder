# Backend environment variables
# Copy to .env and fill in values. Required for mock test generation: GOOGLE_API_KEY.

# Database (Docker: use postgres/redis as host when running in compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=collegefinder_db
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (Docker: use redis as host)
REDIS_HOST=localhost
REDIS_PORT=6379

# Gemini / Google AI – required for mock question generation & admin Social Post Generator (Node backend)
# Get a key: https://aistudio.google.com/app/apikey
# You can use either name; the same key works for Python and Node if you paste it here too.
GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: force a specific Gemini model (e.g. gemini-1.5-flash)
# GEMINI_MODEL=

# Server
PORT=5001
NODE_ENV=development

# Frontend URL for CORS (optional)
# FRONTEND_URL=http://localhost:3000
