{
  "name": "collegefinder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:fast": "next dev",
    "build": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "dev:automation": "concurrently -n py,st -c blue,green \"cd python-backend && ./venv/bin/python -m uvicorn app.main:app --reload --port 8000\" \"npm run dev --prefix stagehand-backend\""
  },
  "dependencies": {
    "@tiptap/extension-color": "^3.13.0",
    "@tiptap/extension-image": "^3.13.0",
    "@tiptap/extension-link": "^3.13.0",
    "@tiptap/extension-text-align": "^3.13.0",
    "@tiptap/extension-text-style": "^3.13.0",
    "@tiptap/extension-underline": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "@types/react-datepicker": "^6.2.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.555.0",
    "next": "16.0.3",
    "react": "19.2.0",
    "react-datepicker": "^8.10.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.5.0",
    "react-qr-code": "^2.0.18",
    "react-quill-new": "^3.2.2",
    "react-rough-notation": "^1.0.8",
    "react-select": "^5.10.2",
    "rough-notation": "^0.5.1",
    "swiper": "^12.0.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
