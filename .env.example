# Frontend Environment Variables
# Copy to .env.local and fill in values

# Backend API URL (used by browser / client-side)
# For local dev: http://localhost:5001/api
# For production: https://your-domain.com/api or http://your-ip/api
NEXT_PUBLIC_API_URL=http://localhost:5001/api

# Server-side API URL (used by Next.js server only - avoids NAT hairpinning on EC2)
# On deployed server: set to http://localhost:5001/api so server calls backend via localhost
# For local dev: can omit (falls back to NEXT_PUBLIC_API_URL)
API_INTERNAL_URL=http://localhost:5001/api
