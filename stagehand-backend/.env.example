# ============= Required for AI browser actions =============
# Use ONE of these (Gemini is preferred):
# Get Gemini key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
# Or: GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here
# Or for OpenAI: OPENAI_API_KEY=your_openai_key_here

# ============= Optional =============
PORT=3001
# Browser: headless=true runs in background (default). Set to false to see the browser window.
# BROWSER_HEADLESS=false
